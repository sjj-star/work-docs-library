{
  "name": "work-docs-library",
  "version": "1.0.0",
  "description": "通用化技术文档知识库管理插件，支持 PDF 提取、知识图谱构建、向量索引与语义搜索",
  "config_file": "config.json",
  "inject": {
    "llm.api_key": "api_key",
    "llm.endpoint": "base_url"
  },
  "tools": [
    {
      "name": "ingest",
      "description": "提取并存储文档到知识库，生成 embedding 和 chunk",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "ingest"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "文件或目录路径"
          },
          "dry_run": {
            "type": "boolean",
            "description": "预览模式，不调用 API",
            "default": false
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "name": "search",
      "description": "基于 FAISS 的语义向量搜索",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "search"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "搜索文本"
          },
          "top_k": {
            "type": "integer",
            "description": "返回结果数量",
            "default": 5
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "query",
      "description": "按章节标题、关键词或概念查询 chunk",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "query"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          },
          "chapter": {
            "type": "string",
            "description": "章节标题子串匹配"
          },
          "chapter_regex": {
            "type": "string",
            "description": "章节标题正则匹配"
          },
          "keyword": {
            "type": "string",
            "description": "关键词匹配"
          },
          "concept": {
            "type": "string",
            "description": "概念名查询（需要配合 doc_id）"
          },
          "top_k": {
            "type": "integer",
            "description": "返回结果数量",
            "default": 10
          }
        }
      }
    },
    {
      "name": "status",
      "description": "列出已导入知识库的所有文档",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "status"
      ],
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "toc",
      "description": "显示文档目录或按标题搜索文档",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "toc"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID，显示完整目录"
          },
          "match": {
            "type": "string",
            "description": "标题模糊匹配关键字"
          }
        }
      }
    },
    {
      "name": "progress",
      "description": "显示文档的总结进度",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "progress"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "reprocess",
      "description": "强制重新处理文档",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "reprocess"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "get_content",
      "description": "获取文档的完整章节或 chunk 原始内容（不截断）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "get_content"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID（查询 chapter/page 时必填）"
          },
          "chapter": {
            "type": "string",
            "description": "章节标题子串匹配"
          },
          "chunk_db_id": {
            "type": "integer",
            "description": "Chunk 数据库 ID"
          }
        }
      }
    },
    {
      "name": "graph_query",
      "description": "查询知识图谱中的实体（按类型或名称搜索）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_query"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型，如 Module, Signal, Register"
          },
          "name": {
            "type": "string",
            "description": "精确名称匹配（需配合 entity_type）"
          },
          "name_pattern": {
            "type": "string",
            "description": "名称模糊匹配（子串，大小写不敏感）"
          }
        }
      }
    },
    {
      "name": "graph_neighbors",
      "description": "查询知识图谱中某实体的邻居节点",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_neighbors"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型"
          },
          "name": {
            "type": "string",
            "description": "实体名称"
          },
          "rel_type": {
            "type": "string",
            "description": "关系类型过滤"
          },
          "direction": {
            "type": "string",
            "description": "方向 out/in/both",
            "default": "out"
          }
        },
        "required": [
          "entity_type",
          "name"
        ]
      }
    },
    {
      "name": "graph_path",
      "description": "查找知识图谱中两实体间的路径",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_path"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "from_type": {
            "type": "string",
            "description": "起点实体类型"
          },
          "from_name": {
            "type": "string",
            "description": "起点实体名称"
          },
          "to_type": {
            "type": "string",
            "description": "终点实体类型"
          },
          "to_name": {
            "type": "string",
            "description": "终点实体名称"
          },
          "max_depth": {
            "type": "integer",
            "description": "最大搜索深度",
            "default": 3
          }
        },
        "required": [
          "from_type",
          "from_name",
          "to_type",
          "to_name"
        ]
      }
    },
    {
      "name": "graph_subgraph",
      "description": "提取以某实体为中心的知识子图",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_subgraph"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "center_type": {
            "type": "string",
            "description": "中心实体类型"
          },
          "center_name": {
            "type": "string",
            "description": "中心实体名称"
          },
          "depth": {
            "type": "integer",
            "description": "搜索深度",
            "default": 1
          },
          "rel_types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "关系类型过滤列表"
          }
        },
        "required": [
          "center_type",
          "center_name"
        ]
      }
    }
  ]
}