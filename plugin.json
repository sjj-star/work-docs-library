{
  "name": "work-docs-library",
  "version": "1.1.0",
  "description": "通用化技术文档知识库管理插件，支持 PDF 提取、知识图谱构建、向量索引与语义搜索。优化后的 API 设计：21 个工具覆盖文档导入、语义搜索、图谱查询与修改、来源溯源与调试。",
  "config_file": "config.json",
  "runtime": {
    "host": "kimi-code",
    "host_version": "1.44.0"
  },
  "inject": {
    "llm.api_key": "api_key",
    "llm.endpoint": "base_url"
  },
  "tools": [
    {
      "name": "ingest",
      "description": "提取并存储文档到知识库，生成 embedding 和 chunk。一键式完成全部四阶段处理。",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "ingest"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "文件或目录路径"
          },
          "dry_run": {
            "type": "boolean",
            "description": "预览模式，不调用 API",
            "default": false
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "name": "semantic_search",
      "description": "语义向量搜索。graph_depth=0 时为纯语义搜索，>0 时联合查询关联的知识图谱实体和子图。",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "semantic_search"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "搜索文本"
          },
          "top_k": {
            "type": "integer",
            "description": "返回结果数量",
            "default": 5
          },
          "graph_depth": {
            "type": "integer",
            "description": "图谱扩展深度，0=纯语义搜索（默认），>0 时扩展关联图谱",
            "default": 0
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "query",
      "description": "按章节标题或概念查询 chunk",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "query"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          },
          "chapter": {
            "type": "string",
            "description": "章节标题子串匹配"
          },
          "chapter_regex": {
            "type": "string",
            "description": "章节标题正则匹配"
          },
          "concept": {
            "type": "string",
            "description": "概念名查询（需要配合 doc_id）"
          },
          "top_k": {
            "type": "integer",
            "description": "返回结果数量",
            "default": 10
          }
        }
      }
    },
    {
      "name": "status",
      "description": "列出已导入知识库的所有文档，或查看指定文档的详细状态和进度统计",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "status"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID，提供时返回该文档的详细状态和进度"
          }
        }
      }
    },
    {
      "name": "toc",
      "description": "显示文档目录或按标题搜索文档",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "toc"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID，显示完整目录"
          },
          "match": {
            "type": "string",
            "description": "标题模糊匹配关键字"
          }
        }
      }
    },
    {
      "name": "reprocess",
      "description": "强制重新处理文档",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "reprocess"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "get_content",
      "description": "获取文档的完整章节或 chunk 原始内容（不截断），可选同时返回关联的图谱实体和关系",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "get_content"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID（查询 chapter 时必填）"
          },
          "chapter": {
            "type": "string",
            "description": "章节标题子串匹配"
          },
          "chunk_db_id": {
            "type": "integer",
            "description": "Chunk 数据库 ID"
          },
          "with_entities": {
            "type": "boolean",
            "description": "是否同时返回关联的图谱实体和关系（默认 false）",
            "default": false
          }
        }
      }
    },
    {
      "name": "graph_query",
      "description": "查询知识图谱实体。depth=0 返回实体信息（默认），depth=1 同时返回邻居，depth>1 同时返回子图。",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_query"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型，如 Module, Signal, Register"
          },
          "name": {
            "type": "string",
            "description": "精确名称匹配（需配合 entity_type）"
          },
          "name_pattern": {
            "type": "string",
            "description": "名称模糊匹配（子串，大小写不敏感）"
          },
          "doc_id": {
            "type": "string",
            "description": "可选，指定文档 ID 以获取该文档中的原始属性快照"
          },
          "depth": {
            "type": "integer",
            "description": "查询深度：0=实体信息（默认），1=邻居，>1=子图",
            "default": 0
          },
          "rel_type": {
            "type": "string",
            "description": "关系类型过滤（depth>=1 时生效）"
          },
          "direction": {
            "type": "string",
            "description": "方向 out/in/both（depth>=1 时生效，默认 out）",
            "default": "out"
          },
          "rel_types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "关系类型过滤列表（depth>1 时生效）"
          }
        }
      }
    },
    {
      "name": "graph_path",
      "description": "查找知识图谱中两实体间的路径",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_path"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "from_type": {
            "type": "string",
            "description": "起点实体类型"
          },
          "from_name": {
            "type": "string",
            "description": "起点实体名称"
          },
          "to_type": {
            "type": "string",
            "description": "终点实体类型"
          },
          "to_name": {
            "type": "string",
            "description": "终点实体名称"
          },
          "max_depth": {
            "type": "integer",
            "description": "最大搜索深度",
            "default": 3
          }
        },
        "required": [
          "from_type",
          "from_name",
          "to_type",
          "to_name"
        ]
      }
    },
    {
      "name": "graph_upsert_entity",
      "description": "添加或更新知识图谱中的实体。若实体已存在则更新属性，不存在则创建。",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_upsert_entity"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型，如 Module, Signal, Register"
          },
          "name": {
            "type": "string",
            "description": "实体名称"
          },
          "properties": {
            "type": "object",
            "description": "实体属性字典"
          },
          "source_doc_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "来源文档 ID 列表"
          },
          "confidence": {
            "type": "number",
            "description": "置信度 0.0-1.0",
            "default": 1.0
          },
          "verified": {
            "type": "boolean",
            "description": "是否已人工验证（可选，不提供时保持原有值）"
          }
        },
        "required": [
          "entity_type",
          "name"
        ]
      }
    },
    {
      "name": "graph_delete_entity",
      "description": "删除知识图谱中的实体（级联删除关联边）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_delete_entity"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型"
          },
          "name": {
            "type": "string",
            "description": "实体名称"
          }
        },
        "required": [
          "entity_type",
          "name"
        ]
      }
    },
    {
      "name": "graph_upsert_relation",
      "description": "添加或更新知识图谱中的关系。若关系已存在则更新属性。",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_upsert_relation"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "rel_type": {
            "type": "string",
            "description": "关系类型"
          },
          "from_type": {
            "type": "string",
            "description": "起点实体类型"
          },
          "from_name": {
            "type": "string",
            "description": "起点实体名称"
          },
          "to_type": {
            "type": "string",
            "description": "终点实体类型"
          },
          "to_name": {
            "type": "string",
            "description": "终点实体名称"
          },
          "properties": {
            "type": "object",
            "description": "关系属性字典"
          },
          "confidence": {
            "type": "number",
            "description": "置信度 0.0-1.0",
            "default": 1.0
          },
          "verified": {
            "type": "boolean",
            "description": "是否已验证",
            "default": false
          }
        },
        "required": [
          "rel_type",
          "from_type",
          "from_name",
          "to_type",
          "to_name"
        ]
      }
    },
    {
      "name": "graph_delete_relation",
      "description": "删除知识图谱中的关系",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_delete_relation"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "rel_type": {
            "type": "string",
            "description": "关系类型"
          },
          "from_type": {
            "type": "string",
            "description": "起点实体类型"
          },
          "from_name": {
            "type": "string",
            "description": "起点实体名称"
          },
          "to_type": {
            "type": "string",
            "description": "终点实体类型"
          },
          "to_name": {
            "type": "string",
            "description": "终点实体名称"
          }
        },
        "required": [
          "rel_type",
          "from_type",
          "from_name",
          "to_type",
          "to_name"
        ]
      }
    },
    {
      "name": "graph_feedback",
      "description": "提交或查询对知识图谱实体/关系的反馈（正确/错误标记）。action=submit 提交反馈，action=query 查询反馈汇总。",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_feedback"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "description": "操作类型：submit（提交反馈，默认）或 query（查询反馈）",
            "default": "submit"
          },
          "rating": {
            "type": "integer",
            "description": "评分 +1（正确）或 -1（错误），submit 时必需"
          },
          "entity_type": {
            "type": "string",
            "description": "目标实体类型"
          },
          "entity_name": {
            "type": "string",
            "description": "目标实体名称"
          },
          "relation_type": {
            "type": "string",
            "description": "目标关系类型"
          },
          "from_type": {
            "type": "string",
            "description": "关系起点实体类型"
          },
          "from_name": {
            "type": "string",
            "description": "关系起点实体名称"
          },
          "to_type": {
            "type": "string",
            "description": "关系终点实体类型"
          },
          "to_name": {
            "type": "string",
            "description": "关系终点实体名称"
          },
          "comment": {
            "type": "string",
            "description": "评论说明"
          },
          "limit": {
            "type": "integer",
            "description": "query 模式下最大返回数量",
            "default": 100
          }
        },
        "required": [
          "action"
        ]
      }
    },
    {
      "name": "graph_conflicts",
      "description": "查询知识图谱冲突日志（同名实体属性覆盖记录）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_conflicts"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型过滤"
          },
          "name": {
            "type": "string",
            "description": "实体名称过滤"
          },
          "limit": {
            "type": "integer",
            "description": "最大返回数量",
            "default": 100
          }
        }
      }
    },
    {
      "name": "graph_provenance",
      "description": "查询知识图谱实体的来源溯源：从实体追溯到提取它的原始文档、章节和 chunk。用于调试和验证图谱准确性。",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_provenance"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型"
          },
          "name": {
            "type": "string",
            "description": "实体名称"
          },
          "doc_id": {
            "type": "string",
            "description": "可选，限定只查某文档的来源"
          }
        },
        "required": [
          "entity_type",
          "name"
        ]
      }
    },
    {
      "name": "doc_parse",
      "description": "将 PDF 文件解析为 Markdown 和图片，输出到 knowledge_base/parsed/{doc_id}/。用户可手动编辑 result.md 后进入阶段2",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "doc_parse"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "PDF 文件路径"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "name": "doc_build_batches",
      "description": "从已解析的 Markdown 生成用于实体提取的 Batch JSONL 文件。执行前可手动编辑 result.md",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "doc_build_batches"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID（即 parsed 目录名）"
          },
          "max_chars": {
            "type": "integer",
            "description": "每个 batch 最大字符数",
            "default": 10000
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "doc_submit_batches",
      "description": "提交 Batch JSONL 到 LLM API，下载并保存原始结果文件（不直接入库）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "doc_submit_batches"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          },
          "file_path": {
            "type": "string",
            "description": "可选，原始 PDF 文件路径（若数据库中无记录则必填）"
          },
          "jsonl_path": {
            "type": "string",
            "description": "可选，自定义 JSONL 路径（默认 knowledge_base/batch/{doc_id}.jsonl）"
          },
          "force": {
            "type": "boolean",
            "description": "强制重新处理，忽略缓存",
            "default": false
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "doc_ingest_results",
      "description": "从 Batch API 结果文件解析实体、构建图谱、保存 chunks（不含向量化，向量化由 doc_submit_embed_batches 完成）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "doc_ingest_results"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          },
          "file_path": {
            "type": "string",
            "description": "可选，原始 PDF 文件路径（若数据库中无记录则必填）"
          },
          "results_path": {
            "type": "string",
            "description": "可选，结果文件路径（默认 knowledge_base/batch/{doc_id}_results.jsonl）"
          },
          "force": {
            "type": "boolean",
            "description": "强制重新处理，忽略缓存",
            "default": false
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "doc_build_embed_jsonl",
      "description": "阶段5：从已入库的 chunks 构建 Embedding Batch JSONL 文件。本地生成，不调用 API，可审查后执行 doc_submit_embed_batches",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "doc_build_embed_jsonl"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "doc_submit_embed_batches",
      "description": "阶段6：提交 Embedding Batch API 并解析结果入库，完成向量化",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "doc_submit_embed_batches"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          },
          "embed_jsonl_path": {
            "type": "string",
            "description": "可选，自定义 Embedding JSONL 路径（默认 knowledge_base/batch/{doc_id}_embed.jsonl）"
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "rebuild_global_graph",
      "description": "全量重建全局知识图谱（清空后从所有子图重新加载，用于修复不一致）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "rebuild_global_graph"
      ],
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "config",
      "description": "打印当前生效的配置参数值（支持敏感字段脱敏）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "config"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "mask_sensitive": {
            "type": "boolean",
            "description": "是否脱敏显示 API Key 等敏感字段",
            "default": true
          }
        }
      }
    }
  ]
}