{
  "name": "work-docs-library",
  "version": "1.0.0",
  "description": "通用化技术文档知识库管理插件，支持 PDF 提取、知识图谱构建、向量索引与语义搜索。支持分阶段处理：doc_parse → doc_build_batches → doc_submit_batches",
  "config_file": "config.json",
  "inject": {
    "llm.api_key": "api_key",
    "llm.endpoint": "base_url"
  },
  "tools": [
    {
      "name": "ingest",
      "description": "提取并存储文档到知识库，生成 embedding 和 chunk",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "ingest"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "文件或目录路径"
          },
          "dry_run": {
            "type": "boolean",
            "description": "预览模式，不调用 API",
            "default": false
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "name": "search",
      "description": "基于 FAISS 的语义向量搜索",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "search"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "搜索文本"
          },
          "top_k": {
            "type": "integer",
            "description": "返回结果数量",
            "default": 5
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "query",
      "description": "按章节标题、关键词或概念查询 chunk",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "query"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          },
          "chapter": {
            "type": "string",
            "description": "章节标题子串匹配"
          },
          "chapter_regex": {
            "type": "string",
            "description": "章节标题正则匹配"
          },
          "keyword": {
            "type": "string",
            "description": "关键词匹配"
          },
          "concept": {
            "type": "string",
            "description": "概念名查询（需要配合 doc_id）"
          },
          "top_k": {
            "type": "integer",
            "description": "返回结果数量",
            "default": 10
          }
        }
      }
    },
    {
      "name": "status",
      "description": "列出已导入知识库的所有文档",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "status"
      ],
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "toc",
      "description": "显示文档目录或按标题搜索文档",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "toc"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID，显示完整目录"
          },
          "match": {
            "type": "string",
            "description": "标题模糊匹配关键字"
          }
        }
      }
    },
    {
      "name": "progress",
      "description": "显示文档的总结进度",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "progress"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "reprocess",
      "description": "强制重新处理文档",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "reprocess"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "get_content",
      "description": "获取文档的完整章节或 chunk 原始内容（不截断）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "get_content"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID（查询 chapter/page 时必填）"
          },
          "chapter": {
            "type": "string",
            "description": "章节标题子串匹配"
          },
          "chunk_db_id": {
            "type": "integer",
            "description": "Chunk 数据库 ID"
          }
        }
      }
    },
    {
      "name": "graph_query",
      "description": "查询知识图谱中的实体（按类型或名称搜索）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_query"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型，如 Module, Signal, Register"
          },
          "name": {
            "type": "string",
            "description": "精确名称匹配（需配合 entity_type）"
          },
          "name_pattern": {
            "type": "string",
            "description": "名称模糊匹配（子串，大小写不敏感）"
          },
          "doc_id": {
            "type": "string",
            "description": "可选，指定文档 ID 以获取该文档中的原始属性快照"
          }
        }
      }
    },
    {
      "name": "graph_neighbors",
      "description": "查询知识图谱中某实体的邻居节点",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_neighbors"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型"
          },
          "name": {
            "type": "string",
            "description": "实体名称"
          },
          "rel_type": {
            "type": "string",
            "description": "关系类型过滤"
          },
          "direction": {
            "type": "string",
            "description": "方向 out/in/both",
            "default": "out"
          },
          "doc_id": {
            "type": "string",
            "description": "可选，指定文档 ID 以获取该文档中的原始属性快照"
          }
        },
        "required": [
          "entity_type",
          "name"
        ]
      }
    },
    {
      "name": "graph_path",
      "description": "查找知识图谱中两实体间的路径",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_path"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "from_type": {
            "type": "string",
            "description": "起点实体类型"
          },
          "from_name": {
            "type": "string",
            "description": "起点实体名称"
          },
          "to_type": {
            "type": "string",
            "description": "终点实体类型"
          },
          "to_name": {
            "type": "string",
            "description": "终点实体名称"
          },
          "max_depth": {
            "type": "integer",
            "description": "最大搜索深度",
            "default": 3
          }
        },
        "required": [
          "from_type",
          "from_name",
          "to_type",
          "to_name"
        ]
      }
    },
    {
      "name": "graph_subgraph",
      "description": "提取以某实体为中心的知识子图",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_subgraph"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "center_type": {
            "type": "string",
            "description": "中心实体类型"
          },
          "center_name": {
            "type": "string",
            "description": "中心实体名称"
          },
          "depth": {
            "type": "integer",
            "description": "搜索深度",
            "default": 1
          },
          "rel_types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "关系类型过滤列表"
          }
        },
        "required": [
          "center_type",
          "center_name"
        ]
      }
    },
    {
      "name": "graph_add_entity",
      "description": "添加或更新知识图谱中的实体",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_add_entity"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型，如 Module, Signal, Register"
          },
          "name": {
            "type": "string",
            "description": "实体名称"
          },
          "properties": {
            "type": "object",
            "description": "实体属性字典"
          },
          "source_doc_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "来源文档 ID 列表"
          },
          "confidence": {
            "type": "number",
            "description": "置信度 0.0-1.0",
            "default": 1.0
          },
          "verified": {
            "type": "boolean",
            "description": "是否已人工验证",
            "default": false
          }
        },
        "required": [
          "entity_type",
          "name"
        ]
      }
    },
    {
      "name": "graph_update_entity",
      "description": "更新知识图谱实体的属性",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_update_entity"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型"
          },
          "name": {
            "type": "string",
            "description": "实体名称"
          },
          "properties": {
            "type": "object",
            "description": "新属性字典（覆盖原有 properties）"
          },
          "confidence": {
            "type": "number",
            "description": "新置信度"
          },
          "verified": {
            "type": "boolean",
            "description": "新验证状态"
          }
        },
        "required": [
          "entity_type",
          "name"
        ]
      }
    },
    {
      "name": "graph_delete_entity",
      "description": "删除知识图谱中的实体（级联删除关联边）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_delete_entity"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型"
          },
          "name": {
            "type": "string",
            "description": "实体名称"
          }
        },
        "required": [
          "entity_type",
          "name"
        ]
      }
    },
    {
      "name": "graph_add_relation",
      "description": "添加或更新知识图谱中的关系",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_add_relation"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "rel_type": {
            "type": "string",
            "description": "关系类型"
          },
          "from_type": {
            "type": "string",
            "description": "起点实体类型"
          },
          "from_name": {
            "type": "string",
            "description": "起点实体名称"
          },
          "to_type": {
            "type": "string",
            "description": "终点实体类型"
          },
          "to_name": {
            "type": "string",
            "description": "终点实体名称"
          },
          "properties": {
            "type": "object",
            "description": "关系属性字典"
          },
          "confidence": {
            "type": "number",
            "description": "置信度 0.0-1.0",
            "default": 1.0
          },
          "verified": {
            "type": "boolean",
            "description": "是否已人工验证",
            "default": false
          }
        },
        "required": [
          "rel_type",
          "from_type",
          "from_name",
          "to_type",
          "to_name"
        ]
      }
    },
    {
      "name": "graph_delete_relation",
      "description": "删除知识图谱中的关系",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_delete_relation"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "rel_type": {
            "type": "string",
            "description": "关系类型"
          },
          "from_type": {
            "type": "string",
            "description": "起点实体类型"
          },
          "from_name": {
            "type": "string",
            "description": "起点实体名称"
          },
          "to_type": {
            "type": "string",
            "description": "终点实体类型"
          },
          "to_name": {
            "type": "string",
            "description": "终点实体名称"
          }
        },
        "required": [
          "rel_type",
          "from_type",
          "from_name",
          "to_type",
          "to_name"
        ]
      }
    },
    {
      "name": "graph_verify_entity",
      "description": "标记知识图谱实体为已验证或取消验证",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_verify_entity"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型"
          },
          "name": {
            "type": "string",
            "description": "实体名称"
          },
          "verified": {
            "type": "boolean",
            "description": "验证状态",
            "default": true
          }
        },
        "required": [
          "entity_type",
          "name"
        ]
      }
    },
    {
      "name": "graph_search_with_graph",
      "description": "语义搜索并联合查询关联的知识图谱实体和子图",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_search_with_graph"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "搜索文本"
          },
          "top_k": {
            "type": "integer",
            "description": "语义搜索返回数量",
            "default": 5
          },
          "graph_depth": {
            "type": "integer",
            "description": "图谱扩展深度",
            "default": 1
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "graph_get_content_with_entities",
      "description": "获取 chunk 内容及其关联的知识图谱实体和关系",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_get_content_with_entities"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "chunk_db_id": {
            "type": "integer",
            "description": "Chunk 数据库 ID"
          },
          "doc_id": {
            "type": "string",
            "description": "可选，指定文档 ID 以获取该文档中的原始属性快照"
          }
        },
        "required": [
          "chunk_db_id"
        ]
      }
    },
    {
      "name": "graph_feedback",
      "description": "提交对知识图谱实体或关系的反馈（正确/错误标记）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_feedback"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "rating": {
            "type": "integer",
            "description": "评分 +1（正确）或 -1（错误）"
          },
          "entity_type": {
            "type": "string",
            "description": "目标实体类型"
          },
          "entity_name": {
            "type": "string",
            "description": "目标实体名称"
          },
          "relation_type": {
            "type": "string",
            "description": "目标关系类型"
          },
          "from_type": {
            "type": "string",
            "description": "关系起点实体类型"
          },
          "from_name": {
            "type": "string",
            "description": "关系起点实体名称"
          },
          "to_type": {
            "type": "string",
            "description": "关系终点实体类型"
          },
          "to_name": {
            "type": "string",
            "description": "关系终点实体名称"
          },
          "comment": {
            "type": "string",
            "description": "评论说明"
          }
        },
        "required": [
          "rating"
        ]
      }
    },
    {
      "name": "graph_conflicts",
      "description": "查询知识图谱冲突日志（同名实体属性覆盖记录）",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "graph_conflicts"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "entity_type": {
            "type": "string",
            "description": "实体类型过滤"
          },
          "name": {
            "type": "string",
            "description": "实体名称过滤"
          },
          "limit": {
            "type": "integer",
            "description": "最大返回数量",
            "default": 100
          }
        }
      }
    },
    {
      "name": "doc_parse",
      "description": "将 PDF 文件解析为 Markdown 和图片，输出到 knowledge_base/parsed/{doc_id}/。用户可手动编辑 result.md 后进入阶段2",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "doc_parse"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "PDF 文件路径"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "name": "doc_build_batches",
      "description": "从已解析的 Markdown 生成用于实体提取的 Batch JSONL 文件。执行前可手动编辑 result.md",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "doc_build_batches"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID（即 parsed 目录名）"
          },
          "max_chars": {
            "type": "integer",
            "description": "每个 batch 最大字符数",
            "default": 10000
          }
        },
        "required": [
          "doc_id"
        ]
      }
    },
    {
      "name": "doc_submit_batches",
      "description": "提交 Batch JSONL 到 LLM API，提取实体、构建图谱、向量化并入库",
      "command": [
        "venv/bin/python3",
        "scripts/plugin_router.py",
        "doc_submit_batches"
      ],
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档 ID"
          },
          "file_path": {
            "type": "string",
            "description": "可选，原始 PDF 文件路径（若数据库中无记录则必填）"
          },
          "jsonl_path": {
            "type": "string",
            "description": "可选，自定义 JSONL 路径（默认 knowledge_base/batch/{doc_id}.jsonl）"
          },
          "force": {
            "type": "boolean",
            "description": "强制重新处理，忽略缓存",
            "default": false
          }
        },
        "required": [
          "doc_id"
        ]
      }
    }
  ]
}