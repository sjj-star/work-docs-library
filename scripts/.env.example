# ============================================
# 开发/独立运行回退配置
# ============================================
# 当作为 Kimi Code CLI 插件运行时，以下配置会被 plugin.json 的 inject 机制覆盖。
# 主配置入口为项目根目录的 config.json（由 Kimi CLI 自动管理凭证）。
# 此 .env 文件仅在以下场景生效：
#   1. 独立运行 Python 脚本（如测试、调试）
#   2. config.json 不存在或对应字段为空
# 详见：https://moonshotai.github.io/kimi-cli/zh/customization/plugins.html
# ============================================

# === LLM 对话模型（实体提取用）===
WORKDOCS_LLM_API_KEY=your_llm_api_key_here
WORKDOCS_LLM_BASE_URL=https://api.moonshot.cn/v1
WORKDOCS_LLM_MODEL=kimi-k2.5
WORKDOCS_LLM_THINKING_ENABLED=0

# === LLM Batch API 配置 ===
WORKDOCS_LLM_BATCH_ENDPOINT=/v1/chat/completions
WORKDOCS_LLM_BATCH_COMPLETION_WINDOW=24h
WORKDOCS_LLM_BATCH_MAX_CHARS=10000
WORKDOCS_LLM_BATCH_TIMEOUT=3600

# === LLM 客户端重试/超时 ===
WORKDOCS_LLM_MAX_RETRIES=3
WORKDOCS_LLM_RETRY_BACKOFF=2
WORKDOCS_LLM_TIMEOUT=120

# === Vision 图片配置（LLM multimodal batch）===
WORKDOCS_LLM_VISION_MAX_EDGE=1024
WORKDOCS_LLM_VISION_QUALITY=85

# === Embedding 模型（向量化用）===
WORKDOCS_EMBEDDING_API_KEY=your_embedding_api_key_here
WORKDOCS_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
WORKDOCS_EMBEDDING_MODEL=embedding-3
WORKDOCS_EMBEDDING_DIMENSION=1024

# === Embedding Batch API 配置 ===
WORKDOCS_EMBEDDING_BATCH_ENDPOINT=/v4/embeddings
WORKDOCS_EMBED_BATCH_MAX_CHARS=4000

# === Embedding 客户端重试/超时 ===
WORKDOCS_EMBED_MAX_RETRIES=3
WORKDOCS_EMBED_RETRY_BACKOFF=2
WORKDOCS_EMBED_TIMEOUT=120
WORKDOCS_EMBED_MAX_BATCH_SIZE=100

# === 文件解析配置（PDF Expert 模式）===
WORKDOCS_PARSER_API_KEY=your_parser_api_key_here
WORKDOCS_PARSER_TIMEOUT=60
WORKDOCS_PARSER_MAX_RETRIES=60
WORKDOCS_PARSER_POLL_INTERVAL=3

# === Batch 处理通用配置 ===
WORKDOCS_BATCH_POLL_INTERVAL=10
WORKDOCS_BATCH_MAX_POLL_RETRIES=360
WORKDOCS_BATCH_MAX_FILE_SIZE_MB=100
WORKDOCS_BATCH_PARALLEL_WORKERS=4
WORKDOCS_BATCH_TEMP_DIR=batch_temp
WORKDOCS_BATCH_FILE_DOWNLOAD_TEMPLATE={base_url}/files/{file_id}/content

# === 同步 API 批处理大小 ===
WORKDOCS_BATCH_SIZE=4

# === Plugin 工具默认值 ===
WORKDOCS_PLUGIN_SEARCH_TOP_K=5
WORKDOCS_PLUGIN_QUERY_TOP_K=10
WORKDOCS_PLUGIN_GRAPH_MAX_DEPTH=3
WORKDOCS_PLUGIN_SUBGRAPH_DEPTH=1
WORKDOCS_PLUGIN_DEFAULT_LIMIT=100

# === Pipeline 业务常量 ===
WORKDOCS_DEFAULT_CHUNK_LEVEL=3
WORKDOCS_DEFAULT_SUMMARY_LENGTH=200
WORKDOCS_CHAPTER_TITLE_MAX_LEN=100
WORKDOCS_CHAPTER_TITLE_MIN_LEN=2

# === 图谱配置 ===
WORKDOCS_GRAPH_MAX_PATH_DEPTH=6
WORKDOCS_GRAPH_OUTPUT_DIR=graphs
