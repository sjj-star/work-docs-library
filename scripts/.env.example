# ============================================
# 配置入口
# ============================================
# 所有配置均通过 WORKDOCS_* 环境变量管理。
# 你可以将本文件复制为 scripts/.env 并填写实际值，或在 Kimi Code CLI 运行环境中注入。
# 配置优先级：环境变量 / .env 文件 > 代码默认值。
# 详见：https://moonshotai.github.io/kimi-code/zh/customization/plugins.html
# ============================================

# === LLM 对话模型（实体提取用）===
# mode 可选 batch 或 chat。
# - batch: 默认推荐，适合大文档，无需保持长连接，稳定性更高。
# - chat: 同步单请求模式，小文件/测试可用；大文档可能因模型处理慢触发 read timeout/499，
#        建议同时调大 WORKDOCS_LLM_TIMEOUT 系列参数。
WORKDOCS_LLM_API_KEY=your_llm_api_key_here
WORKDOCS_LLM_BASE_URL=https://api.moonshot.cn/v1
WORKDOCS_LLM_MODEL=kimi-k2.5
WORKDOCS_LLM_THINKING_ENABLED=0
WORKDOCS_LLM_MODE=batch

# === LLM 同步对话配置 ===
# 同步 Chat 与 Batch 模式共用此 endpoint；Batch 请求体中的完整 endpoint
# 由 LLM_BASE_URL 路径与本值自动推导（如 /v1 + /chat/completions）。
WORKDOCS_LLM_CHAT_ENDPOINT=/chat/completions

# === LLM Batch API 配置 ===
WORKDOCS_LLM_BATCH_COMPLETION_WINDOW=24h
WORKDOCS_LLM_BATCH_MAX_CHARS=10000
WORKDOCS_LLM_BATCH_TIMEOUT=3600

# === Content Block / FAISS 配置 ===
WORKDOCS_BLOCK_MAX_CHARS=6000

# === LLM 同步对话超时 ===
# 基础超时（秒）。当 WORKDOCS_LLM_MODE=chat 时，系统会根据请求文本长度和图片数量
# 自动追加超时：每 10000 字符 + WORKDOCS_LLM_TIMEOUT_PER_10K_CHARS，每张图 + WORKDOCS_LLM_TIMEOUT_PER_IMAGE。
# 最终超时不超过 WORKDOCS_LLM_TIMEOUT_MAX。
WORKDOCS_LLM_TIMEOUT=300
WORKDOCS_LLM_TIMEOUT_PER_10K_CHARS=60
WORKDOCS_LLM_TIMEOUT_PER_IMAGE=30
WORKDOCS_LLM_TIMEOUT_MAX=1800

# === 统一 HTTP 客户端重试/超时（驱动 LLM/Embedding/Batch/Parser 所有 API 调用）===
WORKDOCS_HTTP_TIMEOUT=120
WORKDOCS_HTTP_RETRY_MAX_ATTEMPTS=3
WORKDOCS_HTTP_RETRY_BASE_DELAY=1.0
WORKDOCS_HTTP_RETRY_MAX_DELAY=60.0
WORKDOCS_HTTP_RETRY_JITTER=true
WORKDOCS_HTTP_RETRY_RESPECT_RETRY_AFTER=true

# === 图片压缩配置（multimodal batch 输入）===
# 三层分类策略：基于色度距离自动选择 blackwhite/grayscale/color
WORKDOCS_IMAGE_MAX_SIZE=1024
WORKDOCS_IMAGE_QUALITY=80
WORKDOCS_IMAGE_GRAYSCALE_QUALITY=75
WORKDOCS_IMAGE_GRAYSCALE_CHROMA_DIST=15.0
WORKDOCS_IMAGE_GRAYSCALE_LOW_CHROMA_RATIO=0.95
WORKDOCS_IMAGE_BLACKWHITE_EDGE_RATIO=0.90

# === Embedding 模型（向量化用）===
WORKDOCS_EMBEDDING_API_KEY=your_embedding_api_key_here
WORKDOCS_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
WORKDOCS_EMBEDDING_MODEL=embedding-3
WORKDOCS_EMBEDDING_DIMENSION=1024

# === Embedding 同步 API 配置 ===
WORKDOCS_EMBEDDING_ENDPOINT=/embeddings
# === Embedding 输入长度保护（超长文本自动拆分后 embed 再平均）===
WORKDOCS_EMBED_MAX_CHARS_PER_TEXT=8192
WORKDOCS_EMBED_SPLIT_OVERLONG=true

# === 文件解析配置（PDF Expert 模式）===
WORKDOCS_PARSER_API_KEY=your_parser_api_key_here
WORKDOCS_PARSER_BASE_URL=https://open.bigmodel.cn/api/paas/v4
WORKDOCS_PARSER_TIMEOUT=60
WORKDOCS_PARSER_MAX_RETRIES=60
WORKDOCS_PARSER_POLL_INTERVAL=3

# === PDF Parser 参数（Milestone 1-3 配置化）===
# 图片提取
WORKDOCS_PARSER_MIN_IMAGE_WIDTH=100
WORKDOCS_PARSER_MIN_IMAGE_HEIGHT=100
WORKDOCS_PARSER_PAGE_RENDER_DPI=200
WORKDOCS_PARSER_IMAGE_SIZE_LIMIT=0.05
WORKDOCS_PARSER_MAX_IMAGES_PER_PAGE=30
# 表格检测
WORKDOCS_PARSER_TABLE_DETECTION_ENABLED=true
WORKDOCS_PARSER_TABLE_OVERLAP_THRESHOLD=0.5
WORKDOCS_PARSER_TABLE_MIN_ROWS=2
WORKDOCS_PARSER_TABLE_MIN_COLS=2
WORKDOCS_PARSER_TABLE_MIN_HEIGHT_PT=20.0
WORKDOCS_PARSER_TABLE_MIN_WIDTH_RATIO=0.15
# 文本排版
WORKDOCS_PARSER_TAB_MERGE_THRESHOLD_PT=4.0
# Caption-driven 图像提取
WORKDOCS_PARSER_FIGURE_MIN_SCORE=2.0
WORKDOCS_PARSER_EDGE_LABEL_MAX_LEN=30

# === 目录配置 ===
WORKDOCS_PARSE_OUTPUT_DIR=parsed
WORKDOCS_BATCH_OUTPUT_DIR=batch
WORKDOCS_GRAPH_OUTPUT_DIR=graphs

# === Batch 处理通用配置 ===
WORKDOCS_BATCH_POLL_INTERVAL=10
WORKDOCS_BATCH_MAX_POLL_RETRIES=360
WORKDOCS_BATCH_MAX_FILE_SIZE_MB=100
WORKDOCS_BATCH_PARALLEL_WORKERS=4
WORKDOCS_BATCH_FILE_DOWNLOAD_TEMPLATE={base_url}/files/{file_id}/content

# === Plugin 工具默认值 ===
WORKDOCS_PLUGIN_SEARCH_TOP_K=5
WORKDOCS_PLUGIN_QUERY_TOP_K=10
WORKDOCS_PLUGIN_BM25_TOP_K=50
WORKDOCS_PLUGIN_HYBRID_RRF_K=60
WORKDOCS_PLUGIN_GRAPH_MAX_DEPTH=3
WORKDOCS_PLUGIN_SUBGRAPH_DEPTH=1
WORKDOCS_PLUGIN_DEFAULT_LIMIT=100

# === 图谱配置 ===
WORKDOCS_GRAPH_MAX_PATH_DEPTH=6

# === 使用日志/审计保留策略 ===
WORKDOCS_USAGE_LOG_MAX_DAYS=30
WORKDOCS_USAGE_LOG_MAX_ROWS=10000
