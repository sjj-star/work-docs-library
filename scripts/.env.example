# === LLM 对话模型（总结用）===
WORKDOCS_LLM_PROVIDER=openai
WORKDOCS_LLM_API_KEY=your_llm_api_key_here
WORKDOCS_LLM_BASE_URL=https://api.openai.com/v1
WORKDOCS_LLM_MODEL=gpt-4o-mini
WORKDOCS_LLM_THINKING_ENABLED=0  # 1=启用思考模式

# === Embedding 模型（向量化用）===
WORKDOCS_EMBEDDING_PROVIDER=openai
WORKDOCS_EMBEDDING_API_KEY=your_embedding_api_key_here  # 可不同供应商
WORKDOCS_EMBEDDING_BASE_URL=https://api.openai.com/v1
WORKDOCS_EMBEDDING_MODEL=text-embedding-3-small
WORKDOCS_EMBEDDING_DIM=1536

# === 图像处理配置 ===
WORKDOCS_IMAGE_MAX_EDGE=1024
WORKDOCS_IMAGE_QUALITY=85
WORKDOCS_BATCH_SIZE=4

# === 自动 Vision 描述 ===
# Set to 1 to enable automatic Vision API description for extracted images during ingestion.
# Requires a configured LLM API key with vision support (e.g. GPT-4o, Claude 3, Kimi Vision).
WORKDOCS_AUTO_VISION=0
